---
const today = new Date();
const baseUrl = import.meta.env.BASE_URL;
---

<footer>
	<p>&copy; {today.getFullYear()} DXZ. Built with Astro and deployed on GitHub Pages.</p>
	<div class="footer-links">
		<a href={`${baseUrl}blog/`}>查看文章</a>
		<a href={`${baseUrl}about/`}>关于我</a>
		<a href={`${baseUrl}rss.xml`}>RSS</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	p {
		margin: 0;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1em;
		margin-top: 1em;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
